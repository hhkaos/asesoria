# Base de datos principal (usa el nombre del servicio Docker "db")
DATABASE_URL=postgresql+asyncpg://asesoria:asesoria@db:5432/asesoria

# Base de datos para tests (contenedor separado "db_test")
DATABASE_TEST_URL=postgresql+asyncpg://asesoria:asesoria@db_test:5432/asesoria_test

# JWT — cambiar por un valor aleatorio de al menos 32 caracteres en staging/prod
SECRET_KEY=cambia-esto-en-produccion-minimo-32-caracteres

# Duración de tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Almacenamiento de ficheros subidos
FILES_BASE_PATH=./data/files
MAX_UPLOAD_SIZE_MB=10

# Email (SMTP) — dejar vacío en dev si no se prueban notificaciones
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Hora de ejecución del job diario de actualización de estados (formato HH:MM)
JOB_ESTADOS_HORA=02:00

# Entorno: dev | staging | prod
ENVIRONMENT=dev
